# Backend configuration

# Port the API listens on
PORT=3001

# Where audio files, album art, and the SQLite DB live
# DATA_DIR=/data

# --- Auth (Better Auth) ---
# REQUIRED in production: a long random string used to sign sessions.
BETTER_AUTH_SECRET=change-me-to-a-long-random-string

# Public URL of this API (used by Better Auth).
BETTER_AUTH_URL=http://localhost:3001

# Origin the browser loads the frontend from (CORS + auth CSRF protection).
FRONTEND_ORIGIN=http://localhost:3000

# Optional extra trusted origins for auth, comma-separated.
# BETTER_AUTH_TRUSTED_ORIGINS=https://music.example.com
