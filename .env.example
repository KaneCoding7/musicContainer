# docker-compose environment. Copy to `.env` and fill in.
#   cp .env.example .env

# REQUIRED: a strong, random secret used to sign auth sessions.
# Generate one with: openssl rand -base64 48
BETTER_AUTH_SECRET=

# Public URL the API is reached at (used by Better Auth).
# BETTER_AUTH_URL=http://localhost:3001

# Origin the browser loads the frontend from (CORS + auth CSRF protection).
# For Cloudflare Tunnel, set these to your public hostnames.
# FRONTEND_ORIGIN=http://localhost:3000
# PUBLIC_API_BASE_URL=http://localhost:3001

# Require an invite code to register (the first/owner account is exempt).
# INVITE_ONLY=false
